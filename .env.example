# NeonDB 연결 문자열 (NeonDB 콘솔 → Connection string)
DATABASE_URL="postgresql://user:password@ep-xxx.us-east-1.aws.neon.tech/church_portal?sslmode=require"

# NextAuth 시크릿 (openssl rand -base64 32 로 생성)
NEXTAUTH_SECRET="your-secret-key-here"
NEXTAUTH_URL="http://localhost:3000"

# 관리자 계정 (초기 설정)
ADMIN_EMAIL="***REMOVED***"
ADMIN_PASSWORD_HASH=""  # scripts/hash-password.ts 로 생성

# Gmail SMTP (Google 계정 → 앱 비밀번호 발급)
GMAIL_USER="***REMOVED***"
GMAIL_APP_PASSWORD="xxxx-xxxx-xxxx-xxxx"

# 피드백 알림 수신 이메일
NOTIFY_EMAIL="***REMOVED***"

# Vercel 배포 시 변경
# NEXTAUTH_URL="https://church-portal.vercel.app"
